# Backend Environment Variables
# Copy this file to .env and fill in real values

# Port (Render sets this automatically — leave blank locally or set to 5000)
PORT=5000

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/queuecure?retryWrites=true&w=majority

# Frontend deployed URL (for CORS) — no trailing slash
# Example: https://queue-cure-frontend.onrender.com
CLIENT_URL=https://your-frontend-url.onrender.com
